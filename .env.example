# Template for docker-compose environment variables.
# Copy this file to .env and fill in real values. Do NOT commit .env.

# PostgreSQL container credentials
POSTGRES_DB=ecobrotess
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password

# Connection string used by the API.
# When running with docker-compose, Host must be the postgres service name.
DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=ecobrotess;Username=postgres;Password=your-password
